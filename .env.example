# Backend — copy to `.env` for manual (non-Docker) runs.
# Docker Compose injects these for containerised backend; you usually do not need a `.env` file when using Docker only.

DB_USER=root
DB_PASSWORD=root
DB_HOST=127.0.0.1:3307
DB_NAME=express_tradecom_assignment_db

# Required for JWT; override in production (Docker Compose sets a dev default).
JWT_SECRET_KEY=change-me-in-production
